    },
    {
      "page": "/settings",
      "regex": "^/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/settings(?:/)?$"
    },
    {
      "page": "/subscribers",
      "regex": "^/subscribers(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/subscribers(?:/)?$"
    },
    {
      "page": "/verify-email",
      "regex": "^/verify\\-email(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/verify\\-email(?:/)?$"
    }
